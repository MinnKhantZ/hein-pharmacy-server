PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hein_pharmacy
DB_USER=your_username
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_very_long_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# CORS Configuration
# For single origin (backward compatibility):
# CORS_ORIGIN=http://localhost:8081
# 
# For multiple origins (comma-separated):
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,https://yourdomain.com

# Cloudflare R2 Configuration (public bucket)
R2_REGION=auto
R2_BUCKET=pharmacy-bucket
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_PUBLIC_BASE_URL=https://pharmacy-bucket.your-app.com

# Worker Proxy Configuration
R2_USE_WORKER_PROXY=true
R2_WORKER_URL=https://upload-pharmacy.your-app.com
R2_WORKER_SECRET=your_worker_secret_key
R2_DOWNLOAD_DOMAIN=https://pharmacy-bucket.your-app.com

# Server Proxy Configuration
R2_USE_SERVER_PROXY=true
SERVER_BASE_URL=https://your-server.example.com